# chewyBot Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.
# Required fields must be set before running python bot.py.

# ============================================================
# REQUIRED: Discord
# ============================================================

DISCORD_TOKEN=           # Your bot token from Discord Developer Portal → Bot → Token
                         # NEVER commit your actual token to version control.

GUILD_ID=                # Your Discord server ID (right-click server → Copy Server ID)
                         # Enable Developer Mode in Discord Settings → Advanced → Developer Mode

LOG_CHANNEL_ID=          # Channel ID for bot logs and system alerts
                         # Right-click channel → Copy Channel ID

ARB_CHANNEL_ID=          # Channel ID where arbitrage and +EV alerts are posted
                         # Right-click channel → Copy Channel ID

PARLAY_CHANNEL_ID=       # Channel ID where daily NBA parlay posts appear
                         # Right-click channel → Copy Channel ID

# ============================================================
# REQUIRED: External APIs
# ============================================================

ODDS_API_KEY=            # Your API key from https://the-odds-api.com → Dashboard → API Keys
                         # Free tier: 500 requests/month. Quota is tracked from response headers.

# ============================================================
# OPTIONAL: Arbitrage Scanner Thresholds
# ============================================================

BANKROLL=100.0           # Starting bankroll in USD used for Kelly stake sizing (default: 100.0)
MIN_ARB_PCT=0.5          # Minimum arbitrage % to trigger an alert (default: 0.5)
                         # Lower values → more alerts but smaller edges
ENABLE_EV_SCAN=false     # Set to true to enable +EV scanning (disabled by default — uses extra API requests)
MIN_EV_PCT=2.0           # Minimum +EV % to trigger an alert (default: 2.0)
SCAN_INTERVAL_SECONDS=300 # How often the auto-scanner runs in seconds (default: 300 = 5 min)
                         # Free tier (500 req/mo): use 3600+ to stay under quota
                         # Paid tier: 300 is reasonable, odds rarely shift faster
ENABLED_SPORTS=basketball_nba,americanfootball_nfl,icehockey_nhl
                         # Comma-separated sport keys to scan. Valid values:
                         # basketball_nba, americanfootball_nfl, icehockey_nhl,
                         # baseball_mlb, soccer_epl (Phase 3+)

# ============================================================
# OPTIONAL: NBA Parlay AI
# ============================================================

BALLDONTLIE_API_KEY=     # API key from https://www.balldontlie.io → Dashboard
                         # Required for live NBA player stats used by the parlay AI
                         # Leave blank to use MOCK_MODE=true for development

PARLAY_POST_TIME=11:00   # Daily parlay post time in Eastern Time, 24-hour format (default: 11:00)
                         # Example: 11:00 → 11:00 AM ET, 20:30 → 8:30 PM ET

PARLAY_LEARNING_RATE=0.05  # How quickly factor weights update from Discord reactions (default: 0.05)
                           # Formula: new_weight = old_weight + (learning_rate * delta)
                           # Higher values → faster adaptation but more variance

MIN_LEG_SCORE=0.5        # Minimum leg score (0.0–1.0) for a leg to be included in a parlay (default: 0.5)
                         # Higher values → fewer but higher-confidence legs

# ============================================================
# OPTIONAL: Text-to-Speech
# ============================================================

TTS_INTERRUPTS_MUSIC=false   # Whether /tts interrupts current music playback (default: false)
                             # true → stops music, speaks, resumes; false → queues after current song

TTS_MAX_CHARS=300            # Maximum character limit for /tts command input (default: 300)
                             # Prevents abuse and keeps audio clips short

# ============================================================
# OPTIONAL: Development & Testing
# ============================================================

MOCK_MODE=false          # Use mock JSON files instead of live API calls (default: false)
                         # true → loads from mock/odds_api_sample.json and mock/balldontlie_sample.json
                         # Useful for development without consuming API quota
